   "source": [
    "# -----------------------------------\n",
    "# 2. ?뱀씠媛?遺꾪빐 (Singular Value Decomposition, SVD)\n",
    "# -----------------------------------\n",
    "# (吏곸궗媛곹삎 ?됰젹 3x2 - ?욎꽑 ?곗씠???덉떆)\n",
    "A_rect = np.array([\n",
    "    [1, 2],\n",
    "    [3, 4],\n",
    "    [5, 6]\n",
    "])\n",
    "\n",
    "print(\"=== 吏곸궗媛곹삎 ?됰젹 A_rect (3x2) ===\\n\", A_rect)\n",
    "\n",
    "# ?뱀씠媛?遺꾪빐 (A = U * Sigma * V^T)\n",
    "# U: (3x3) ?쇱そ ?뱀씠踰≫꽣 ?됰젹\n",
    "# S: (2,) 1李⑥썝 諛곗뿴濡????뱀씠媛?(Singular values)\n",
    "# VT: (2x2) ?ㅻⅨ履??뱀씠踰≫꽣 ?됰젹\n",
    "U, S, VT = np.linalg.svd(A_rect)\n",
    "\n",
