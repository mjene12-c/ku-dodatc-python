   "source": [
    "import numpy as np\n",
    "\n",
    "# 鍮쏆쓽 ?띾룄 (km/s)\n",
    "C = 299792.458 \n",
    "\n",
    "# [1. ?쒕??덉씠???섍꼍 援ъ꽦]\n",
    "# 6媛??꾩꽦???꾩쓽 3李⑥썝 醫뚰몴 (怨좊룄 ??20,000km ?섏?)\n",
    "satellites = np.array([\n",
    "    [15000, 12000, 20000],\n",
    "    [-10000, 18000, 22000],\n",
    "    [1000, -15000, 21000],\n",
    "    [14000, -10000, 23000],\n",
    "    [-12000, -8000, 24000],\n",
    "    [-5000, 16000, 25000]\n",
    "])\n",
    "\n",
    "# ?ъ슜?먯쓽 ?ㅼ젣 3李⑥썝 ?꾩튂 (?곕━媛 SVD ??궛?쇰줈 李얠븘?댁빞 ???뺣떟)\n",
    "true_pos = np.array([300, 400, 50])\n",
    "true_clock_bias = 0.00001 # ?섏떊湲곗쓽 ?ㅼ젣 ?쒓컙 ?ㅼ감 (珥??⑥쐞)\n",
    "\n",
    "# (媛???앹꽦) ?꾩꽦???좏샇瑜?蹂대궦 ?쒓컙 t_i 諛곗뿴 ?앹꽦\n",
    "# ?ㅼ젣 嫄곕━ / 鍮쏆쓽 ?띾룄 = ?꾨떖??嫄몃┛ ?쒖닔 ?쒓컙\n",
    "transmit_times = []\n",
    "receiver_time = 100.0 # ?섏떊湲곌? ?좏샇瑜?諛쏆? ?섏떊湲?湲곗? ?쒓컙(遺덉븞?뺥븿)\n",
    "\n",
    "# 媛??꾩꽦???좏샇瑜??≪떊???쒓컙(t_i)????쑝濡??쒕??덉씠?섑븯???쒕떎怨?媛??n",
    "for sat in satellites:\n",
    "    real_dist = np.linalg.norm(sat - true_pos)\n",
    "    pure_travel_time = real_dist / C\n",
    "    \n",
    "    # ?섏떊湲곌? 100.0珥덉뿉 諛쏆븯?ㅺ퀬 ?좊븣, ?ㅼ젣 ?몄긽 ?쒓컙? 100.0 - ?ㅼ감\n",
    "    true_receiver_time = receiver_time - true_clock_bias\n",
    "    t_i = true_receiver_time - pure_travel_time\n",
    "    transmit_times.append(t_i)\n",
    "transmit_times = np.array(transmit_times)\n",
    "\n",
    "# --- ?ш린源뚯?媛 GPS ?꾩꽦 ?쒖뒪?쒖씠 ?덇났????\"?④꺼吏??뺣떟\" ?낅땲??---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [],
   "source": [
    "# [2. ?섏떊湲곌? ?곗씠?곕? 諛쏆븘??Pseudo-range (?섏궗 嫄곕━) 痢≪젙]\n",
    "# ?섏떊湲곕뒗 ?꾩꽦 ?꾩튂(satellites)? ?≪떊 ?쒓컙(transmit_times)???꾨떖諛쏄퀬, ?먯떊???섏떊 ?쒓컙(receiver_time)??類띾땲??\n",
    "\n",
    "pseudo_ranges = []\n",
    "for t_i in transmit_times:\n",
    "    # P = c * (?섏떊湲??쒓퀎 ?쒓컙 - ?꾩꽦 ?≪떊 ?쒓컙)\n",
    "    # ??嫄곕━ ?덉뿉??(?ㅼ젣 嫄곕━ + c*?섏떊湲??쒓컙?ㅼ감) 媛 ?욎뿬 ?덉뒿?덈떎.\n",
    "    noise = np.random.normal(0, 0.001) # ?湲곌텒 ?듦낵 ?꾪뙆 吏?????쎄컙???몄씠利?n",
    "    P_i = C * (receiver_time - t_i) + noise \n",
    "    pseudo_ranges.append(P_i)\n",
    "pseudo_ranges = np.array(pseudo_ranges)\n"
   ]
