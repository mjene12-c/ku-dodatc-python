    "    # b 踰≫꽣: Xi^2 - X1^2 + Yi^2 - Y1^2 + Zi^2 - Z1^2 - Pi^2 + P1^2\n",
    "    b_val = (xi**2 - x1**2) + (yi**2 - y1**2) + (zi**2 - z1**2) - (Pi**2 - P1**2)\n",
    "    b.append(b_val)\n",
    "\n",
    "A = np.array(A) # ?ш린: 5 x 4\n",
    "b = np.array(b) # ?ш린: 5\n"
