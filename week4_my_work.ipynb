    "reduced = tsne.fit_transform(vectors)\n",
    "\n",
    "category_map = {\n",
    "    '?숇Ъ':  ['媛뺤븘吏', '怨좎뼇??, '?ъ옄', '?몃옉??, '諛섎젮?숇Ъ'],\n",
    "    'IT/AI': ['?뚯씠??, '?λ윭??, '癒몄떊?щ떇', '?좉꼍留?, 'AI', '?먯뿰?댁쿂由?],\n",
    "    '?꾩떆':  ['?쒖슱', '遺??, '?섎룄', '?꾩떆'],\n",
    "    '?ㅽ룷痢?:['?쇨뎄', '異뺢뎄', '?ㅽ룷痢?],\n",
    "    '?뚯떇':  ['?ш낵', '諛붾굹??, '?밴렐', '?ㅼ씠', '怨쇱씪', '梨꾩냼'],\n",
    "}\n",
    "palette = {'?숇Ъ': '#f87171', 'IT/AI': '#4f8ef7', '?꾩떆': '#34d399',\n",
    "           '?ㅽ룷痢?: '#fbbf24', '?뚯떇': '#a78bfa', '湲고?': '#aaa'}\n",
    "\n",
    "word_colors = {}\n",
    "for w in words:\n",
    "    word_colors[w] = palette['湲고?']\n",
    "    for cat, cws in category_map.items():\n",
