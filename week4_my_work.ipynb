    "    \"異뺢뎄? ?쇨뎄??? ?ㅽ룷痢좎씠??",\n",
    "    \"?ш낵? 諛붾굹?섎뒗 怨쇱씪?대떎\",\n",
    "    \"?밴렐怨??ㅼ씠??梨꾩냼?대떎\",\n",
    "]\n",
    "\n",
    "# 媛꾨떒 ?꾩쿂由?(怨듬갚 遺꾨━)\n",
    "remove_chars = ['?', '??, '?대떎', '?', '怨?, '??, '??, '??]\n",
    "tokenized = []\n",
    "for sent in corpus:\n",
