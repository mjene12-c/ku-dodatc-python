    "print(f\"??Word2Vec ?숈뒿 ?꾨즺 | ?댄쐶: {len(w2v.wv.key_to_index)}媛??⑥뼱\")\n",
    "\n",
    "for word in ['媛뺤븘吏', '?뚯씠??, '?쒖슱']:\n",
    "    if word in w2v.wv:\n",
    "        similar = w2v.wv.most_similar(word, topn=3)\n",
