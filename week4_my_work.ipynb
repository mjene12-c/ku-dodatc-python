   "source": [
    "data_raw = np.array([10.0, 20.0, 30.0, 40.0, 50.0, 200.0])  # ?댁긽移??ы븿\n",
    "\n",
    "# ?? 吏곸젒 援ы쁽 ??????????????????????????????????????\n",
    "# Min-Max ?뺢퇋??n",
    "def min_max_normalize(x):\n",
    "    return (x - x.min()) / (x.max() - x.min())\n",
    "\n",
    "# Z-score ?쒖???n",
    "def z_score_standardize(x):\n",
    "    return (x - x.mean()) / x.std()\n",
    "\n",
    "mm  = min_max_normalize(data_raw)\n",
    "std = z_score_standardize(data_raw)\n",
    "\n",
    "df_compare = pd.DataFrame({\n",
    "    '?먮낯': data_raw,\n",
    "    'Min-Max ?뺢퇋??: mm.round(3),\n",
    "    'Z-score ?쒖???: std.round(3),\n",
    "})\n",
    "print(df_compare.to_string(index=False))\n",
    "print(f\"\\nMin-Max 踰붿쐞: [{mm.min():.2f}, {mm.max():.2f}]\")\n",
    "print(f\"Z-score  ?됯퇏: {std.mean():.4f}, ?쒖??몄감: {std.std():.4f}\")"
   ]
