   "source": [
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "# ?? ?쒖꽌 ?녿뒗 踰붿＜ (Label Encoding 二쇱쓽 ?꾩슂) ??????????????\n",
    "colors = ['鍮④컯', '?뚮옉', '珥덈줉', '鍮④컯', '?뚮옉', '珥덈줉', '鍮④컯']\n",
    "\n",
    "le = LabelEncoder()\n",
    "encoded = le.fit_transform(colors)\n",
    "\n",
    "print(\"=== Label Encoding ===\")\n",
    "print(f\"?대옒?? {le.classes_}\")\n",
    "print(f\"?먮낯:   {colors}\")\n",
    "print(f\"?몄퐫?? {encoded}\")\n",
    "print(f\"????? {list(le.inverse_transform(encoded))}\")\n",
    "\n",
    "# ?? ?쒖꽌 ?덈뒗 踰붿＜ (pandas map ?쒖슜) ???????????????????????\n",
    "df_grade = pd.DataFrame({\n",
    "    'name':  ['Alice', 'Bob', 'Carol', 'Dave', 'Eve'],\n",
    "    'grade': ['A', 'C', 'B', 'F', 'A'],\n",
    "})\n",
    "\n",
    "grade_map = {'F': 0, 'D': 1, 'C': 2, 'B': 3, 'A': 4}\n",
    "df_grade['grade_enc'] = df_grade['grade'].map(grade_map)\n",
    "\n",
    "print(\"\\n=== ?쒖꽌 ?덈뒗 踰붿＜ ??pandas map ===\")\n",
    "print(df_grade)"
   ]
