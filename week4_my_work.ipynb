    "        top  = sims.argsort()[::-1][:top_k]\n",
    "        print(f\"\\n?뵇 荑쇰━: '{query}'\")\n",
    "        for rank, i in enumerate(top, 1):\n",
    "            print(f\"  [{rank}?? {sims[i]:.3f}  {docs[i]}\")\n",
    "\n",
    "    for q in [\"?쒓컖???쇱씠釉뚮윭由??ъ슜踰?", \"?띿뒪???꾨쿋??紐⑤뜽\", \"?곗씠???꾩쿂由?諛⑸쾿\"]:\n",
    "        semantic_search(q)"
