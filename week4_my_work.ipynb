    "                fontsize=8.5, color=word_colors.get(word, '#aaa'))\n",
    "\n",
    "ax.set_title('Word2Vec ?꾨쿋??t-SNE ?쒓컖??, fontsize=13)\n",
    "ax.legend(fontsize=10); ax.grid(alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig('6_word2vec_tsne.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
