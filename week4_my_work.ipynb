    "        \"?곗씠???꾩쿂由? ?뺢퇋?붿? ?몄퐫??\",\n",
    "    ]\n",
    "    doc_emb = sbert.encode(docs)\n",
    "\n",
    "    def semantic_search(query, top_k=3):\n",
